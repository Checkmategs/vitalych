[Unit]
Description=Vitalych GOST document generator (API + UI)
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/vitalych
ExecStart=/opt/vitalych/.venv/bin/uvicorn api.main:app --host 0.0.0.0 --port 8080
Restart=on-failure
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
